<?php
/**
 * ESTE ES UN ARCHIVO DE EJEMPLO
 * Para que el sitio funcione:
 * 1. Copia este archivo y renombralo a "config.php"
 * 2. Rellena los datos con tus credenciales de InfinityFree o Localhost
 */

$host = 'TU_HOST_AQUI';      // Ejemplo: sql113.infinityfree.com o localhost
$db   = 'TU_BASE_DE_DATOS';  // Ejemplo: if0_41704597_tienda
$user = 'TU_USUARIO';       // Ejemplo: if0_41704597 o root
$pass = 'TU_CONTRASEÑA';    // Tu contraseña de MySQL

try {
    $pdo = new PDO("mysql:host=$host;dbname=$db;charset=utf8", $user, $pass);
    $pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);
} catch (PDOException $e) {
    // No mostramos detalles del error en producción por seguridad
    die("Error crítico: No se pudo conectar a la base de datos.");
}
?>